# D2Farm Backend — Environment Variables
# Copy this to .env and fill in your values

# MongoDB Atlas Connection String
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/d2farm?retryWrites=true&w=majority

# Server Port (Vercel ignores this — only used locally)
PORT=4000

# CORS — set to your deployed frontend URLs (comma-separated if multiple)
FRONTEND_URL=https://your-buyer-app.vercel.app
FARMER_URL=https://your-farmer-app.vercel.app
